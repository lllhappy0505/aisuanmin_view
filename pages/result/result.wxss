/* result.wxss */
.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  position: relative;
}

.background-pattern {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    linear-gradient(135deg, rgba(139, 0, 0, 0.03) 0%, rgba(220, 20, 60, 0.05) 100%),
    url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><text x="10" y="50" font-size="60" fill="rgba(139,0,0,0.1)">☯</text></svg>');
  background-size: cover, 100px 100px;
  z-index: 0;
  pointer-events: none;
}

.header-section {
  text-align: center;
  padding: 40rpx 0 30rpx;
  position: relative;
  z-index: 1;
}

.title-decoration {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #8B0000, transparent);
  margin: 20rpx auto;
}

.result-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #8B0000;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(139, 0, 0, 0.1);
}

.user-info {
  display: block;
  font-size: 26rpx;
  color: #8B0000;
  opacity: 0.8;
  letter-spacing: 2rpx;
}

.birthday-info {
  background: linear-gradient(135deg, #DC143C 0%, #8B0000 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #8B0000;
  box-shadow: 0 4rpx 12rpx rgba(139, 0, 0, 0.3);
  position: relative;
  z-index: 1;
}

.birthday-text {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.bazi-section,
.wuxing-section,
.analysis-section,
.detail-section,
.dayun-section,
.zang-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 0, 0, 0.15);
  border: 2rpx solid #E8D0D0;
  position: relative;
  z-index: 1;
}

.section-header {
  text-align: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #DC143C;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B0000;
  letter-spacing: 4rpx;
}

.bazi-table {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bazi-header {
  display: flex;
  gap: 8rpx;
}

.header-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #8B0000;
  opacity: 0.7;
  padding: 12rpx 0;
  background: #FFF8F8;
  border-radius: 8rpx;
  border: 1rpx solid #E8D0D0;
}

.bazi-row {
  display: flex;
  gap: 8rpx;
}

.bazi-item {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  padding: 16rpx 0;
  background: linear-gradient(135deg, #DC143C 0%, #8B0000 100%);
  border-radius: 8rpx;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(139, 0, 0, 0.3);
}

.wuxing-content,
.analysis-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #E8D0D0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #8B0000;
  font-weight: 500;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
}

.wuxing-text,
.analysis-text {
  font-size: 28rpx;
  color: #666;
  line-height: 2;
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #E8D0D0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #8B0000;
  flex-shrink: 0;
  font-weight: 500;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.dayun-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dayun-item {
  background: linear-gradient(135deg, #FFF8F8 0%, #FFE8E8 100%);
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #E8D0D0;
}

.dayun-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dayun-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B0000;
}

.dayun-ganzhi {
  font-size: 32rpx;
  font-weight: bold;
  color: #DC143C;
}

.dayun-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dayun-detail {
  font-size: 24rpx;
  color: #666;
}

.dayun-footer {
  text-align: center;
}

.dayun-extra {
  font-size: 24rpx;
  color: #8B0000;
  opacity: 0.8;
}

.zang-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.zang-row {
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.zang-item {
  flex: 1;
  height: 60rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E0E0E0;
}

.zang-item.active {
  background: linear-gradient(135deg, #DC143C 0%, #8B0000 100%);
  border-color: #8B0000;
  box-shadow: 0 2rpx 8rpx rgba(139, 0, 0, 0.3);
}

.zang-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.zang-item.active .zang-name {
  color: #fff;
}

.button-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.back-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #DC143C 0%, #8B0000 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(139, 0, 0, 0.4);
  position: relative;
  overflow: hidden;
}

.back-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent,
    rgba(255, 255, 255, 0.1),
    transparent
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% {
    left: -50%;
  }
  100% {
    left: 150%;
  }
}

.back-btn::after {
  border: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}
